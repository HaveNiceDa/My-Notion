{
  "name": "@notion/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start",
    "dev:local": "EXPO_PUBLIC_AI_SERVICE_URL=http://localhost:3001 expo start",
    "dev:convex": "npx convex dev --typecheck=disable",
    "dev:all": "concurrently \"pnpm run dev\" \"pnpm run dev:convex\"",
    "dev:all:local": "concurrently \"pnpm run dev:local\" \"pnpm run dev:convex\"",
    "start": "expo start",
    "export": "npx expo export",
    "build:preview": "eas build --platform android --profile preview",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint app/",
    "clean": "rd /s /q node_modules 2>nul || exit 0"
  },
  "dependencies": {
    "@10play/react-native-web-webview": "^0.0.3",
    "@10play/tentap-editor": "^1.0.1",
    "@clerk/expo": "^3.1.12",
    "@expo/vector-icons": "^15.0.3",
    "@notion/ai": "workspace:*",
    "@notion/business": "workspace:*",
    "@notion/convex": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@tamagui/animations-react-native": "2.0.0-rc.41",
    "@tamagui/config": "2.0.0-rc.41",
    "convex": "^1.37.0",
    "expo": "~54.0.34",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "^17.0.11",
    "expo-linking": "~8.0.12",
    "expo-localization": "^17.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "i18next": "^26.0.5",
    "openai": "^6.33.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "^13.15.0",
    "react-native-worklets": "0.5.1",
    "tamagui": "2.0.0-rc.41",
    "twrnc": "^4.16.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
