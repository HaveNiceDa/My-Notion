{
  "name": "notion-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/business/*"
  ],
  "scripts": {
    "build": "pnpm run build --filter 'apps/*'",
    "dev": "pnpm run dev --filter 'apps/*'",
    "start:web": "pnpm --filter notion-web dev",
    "start:convex": "npx convex dev --dir services/convex",
    "clean": "pnpm -r exec rm -rf node_modules"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "resolutions": {
    "prosemirror-view": "^1.31.4"
  }
}
