{
  "name": "notion-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:web": "pnpm --filter @notion/web build",
    "build:mobile": "pnpm --filter @notion/mobile build",
    "dev": "pnpm run dev --filter 'apps/*'",
    "start:web": "pnpm --filter @notion/web start",
    "start:mobile": "pnpm --filter @notion/mobile start",
    "clean": "rd /s /q node_modules 2>nul || exit 0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "rimraf": "^6.1.3"
  },
  "resolutions": {
    "prosemirror-view": "^1.31.4"
  }
}
