{
  "name": "notion-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:web": "pnpm --filter @notion/web build",
    "build:mobile": "pnpm --filter @notion/mobile export",
    "dev": "pnpm run dev --filter 'apps/*'",
    "start:web": "pnpm --filter @notion/web start",
    "start:mobile": "pnpm --filter @notion/mobile dev:all",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci:ai-smoke": "node scripts/ci-ai-smoke.mjs",
    "eval:retrieval": "tsx packages/ai/eval/retrieval-eval-runner.ts",
    "eval:memory": "tsx packages/ai/eval/memory-eval-runner.ts",
    "e2e:cli": "node scripts/e2e-my-notion-cli.mjs",
    "e2e:cli:errors": "node scripts/e2e-my-notion-cli-errors.mjs",
    "e2e:mcp": "node scripts/e2e-my-notion-mcp.mjs",
    "e2e:mcp:client": "node scripts/e2e-my-notion-mcp-sdk-client.mjs",
    "sync:skills": "node scripts/sync-my-notion-skills.mjs",
    "sync:skills:package": "node scripts/sync-my-notion-package-skills.mjs",
    "sync:skills:check": "node scripts/sync-my-notion-skills.mjs --check",
    "clean": "rd /s /q node_modules 2>nul || exit 0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.39",
    "concurrently": "^9.2.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  },
  "resolutions": {
    "prosemirror-view": "^1.31.4",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  }
}
