{
  "name": "notion-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:web": "pnpm --filter @notion/web build",
    "build:mobile": "pnpm --filter @notion/mobile build",
    "dev": "pnpm run dev --filter 'apps/*'",
    "start:web": "pnpm --filter @notion/web start",
    "start:mobile": "pnpm --filter @notion/mobile start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rd /s /q node_modules 2>nul || exit 0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.39",
    "concurrently": "^9.2.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  },
  "resolutions": {
    "prosemirror-view": "^1.31.4",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  }
}
