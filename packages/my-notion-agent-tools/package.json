{
  "name": "@mynotion/agent-tools",
  "version": "0.1.0",
  "description": "Shared My-Notion Agent tool contracts and Machine API client",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "my-notion",
    "agent",
    "tools",
    "documents"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
