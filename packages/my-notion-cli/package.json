{
  "name": "@mynotion/cli",
  "version": "0.1.0",
  "description": "Agent-native CLI and MCP adapter for My-Notion documents",
  "type": "module",
  "bin": {
    "my-notion": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "docs",
    "skills",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "dev": "tsx src/index.ts",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "pnpm run sync:skills && pnpm run build",
    "release:beta": "npm publish --tag beta --access public",
    "release:latest": "npm publish --tag latest --access public",
    "sync:skills": "node ../../scripts/sync-my-notion-package-skills.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "my-notion",
    "notion",
    "cli",
    "agent",
    "mcp",
    "skills",
    "documents"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HaveNiceDa/My-Notion.git",
    "directory": "packages/my-notion-cli"
  },
  "bugs": {
    "url": "https://github.com/HaveNiceDa/My-Notion/issues"
  },
  "homepage": "https://github.com/HaveNiceDa/My-Notion#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.9.0",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
