{
  "name": "@mynotion/mcp",
  "version": "0.1.3",
  "description": "Standalone MCP STDIO server for My-Notion document tools",
  "type": "module",
  "bin": {
    "my-notion-mcp": "dist/index.js",
    "my-notion-mcp-server": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/index.ts src/server.ts src/register-tools.ts src/result-adapter.ts --bundle --platform=node --format=esm --outdir=dist --outbase=src --external:@modelcontextprotocol/sdk/* --external:zod",
    "clean": "rimraf dist",
    "dev": "tsx src/index.ts",
    "pack:dry-run": "pnpm publish --dry-run --no-git-checks",
    "prebuild": "pnpm --filter @mynotion/agent-tools build",
    "pretest": "pnpm --filter @mynotion/agent-tools build",
    "release:beta": "pnpm publish --tag beta --access public",
    "release:latest": "pnpm publish --tag latest --access public",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "my-notion",
    "mcp",
    "model-context-protocol",
    "agent",
    "documents"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@mynotion/agent-tools": "workspace:^0.1.0",
    "@types/node": "^20",
    "esbuild": "^0.27.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
