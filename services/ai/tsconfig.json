{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "../..",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "src/**/*",
    "../../packages/ai/config/**/*",
    "../../packages/ai/embeddings/**/*",
    "../../packages/ai/prompts/**/*",
    "../../packages/ai/rag/**/*",
    "../../packages/ai/server/**/*",
    "../../packages/ai/tools/**/*",
    "../../packages/ai/utils/**/*"
  ],
  "exclude": ["node_modules", "dist", "../../packages/ai/__tests__/**/*"]
}
